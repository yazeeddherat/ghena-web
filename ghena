# ================= الإعدادات =================
class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    BOLD = '\033[1m'
    ENDC = '\033[0m'

# ================= إدارة الجلسات =================
class Session:
    def __init__(self, target: str = None):
        self.target = target
        self.commands = []  # سجل الأوامر المنفذة
        self.start_time = datetime.datetime.now().isoformat()
    
    def add_command(self, cmd: str, output: str):
        self.commands.append({
            "time": datetime.datetime.now().isoformat(),
            "command": cmd,
            "output": output
        })
    
    def save(self, filename: str = None):
        if not filename:
            filename = f"session_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        with open(filename, 'w') as f:
            json.dump({
                "target": self.target,
                "start_time": self.start_time,
                "commands": self.commands
            }, f, indent=2)
        print(f"{Colors.GREEN}💾 تم حفظ الجلسة في {filename}{Colors.ENDC}")
        return filename
    
    @staticmethod
    def load(filename: str):
        with open(filename, 'r') as f:
            data = json.load(f)
        session = Session(data.get('target'))
        session.start_time = data['start_time']
        session.commands = data['commands']
        return session

# ================= تنفيذ الأوامر =================
def run_command(cmd: str) -> str:
    """تنفيذ أمر وعودة الناتج"""
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=300)
        return result.stdout + result.stderr
    except Exception as e:
        return f"خطأ في تنفيذ الأمر: {e}"

def execute_and_log(session: Session, cmd: str):
    """تنفيذ الأمر وعرض النتيجة وتسجيلها في الجلسة"""
    print(f"{Colors.GREEN}▶ تنفيذ: {cmd}{Colors.ENDC}")
    output = run_command(cmd)
    print(output)
    session.add_command(cmd, output)

