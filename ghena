def handle_choice(session: Session, choice: str):
    if choice == '1':  # Nmap
        target = session.target if session.target else input("أدخل الهدف (IP/URL): ").strip()
        if not session.target:
            session.target = target
        options = input("خيارات إضافية (مثل -sC -sV): ").strip()
        cmd = f"nmap {options} {target}"
        execute_and_log(session, cmd)
    
    elif choice == '2':  # Gobuster
        url = input("URL الهدف (مثال: http://example.com): ").strip()
        wordlist = input("مسار قائمة الكلمات (افتراضي: /usr/share/wordlists/dirb/common.txt): ").strip()
        if not wordlist:
            wordlist = "/usr/share/wordlists/dirb/common.txt"
        options = input("خيارات إضافية: ").strip()
        cmd = f"gobuster dir -u {url} -w {wordlist} {options}"
        execute_and_log(session, cmd)
    
    elif choice == '3':  # Searchsploit
        query = input("أدخل اسم الخدمة أو الإصدار: ").strip()
        cmd = f"searchsploit {query}"
        execute_and_log(session, cmd)
    
    elif choice == '4':  # Hydra
        service = input("الخدمة (ssh/ftp/http-post-form...): ").strip()
        target = input("الهدف: ").strip()
        user = input("اسم المستخدم (أو -L لملف): ").strip()
        password = input("كلمة المرور (أو -P لملف): ").strip()
        options = input("خيارات إضافية (مثل -t 4): ").strip()
        cmd = f"hydra -l {user} -p {password} {service}://{target} {options}"
        execute_and_log(session, cmd)
    
    elif choice == '5':  # Curl
        url = input("URL: ").strip()
        options = input("خيارات إضافية (مثل -I): ").strip()
        cmd = f"curl {options} {url}"
        execute_and_log(session, cmd)
    
    elif choice == '6':  # Netcat
        target = input("الهدف: ").strip()
        port = input("المنفذ: ").strip()
        mode = input("وضع (connect/listen): ").strip().lower()
        if mode.startswith('c'):
            cmd = f"nc {target} {port}"
        else:
            cmd = f"nc -lvnp {port}"
        execute_and_log(session, cmd)
    
    elif choice == '7':  # Msfconsole
        resource = input("ملف أوامر (اختياري): ").strip()
        if resource:
            cmd = f"msfconsole -r {resource}"
        else:
            cmd = "msfconsole"
        execute_and_log(session, cmd)
    
    elif choice == '8':  # Nikto
        target = input("الهدف: ").strip()
        options = input("خيارات إضافية: ").strip()
        cmd = f"nikto -h {target} {options}"
        execute_and_log(session, cmd)
    
    elif choice == '9':  # Wfuzz
        url = input("URL (استخدم FUZZ كمكان للاختبار): ").strip()
        wordlist = input("مسار قائمة الكلمات: ").strip()
        options = input("خيارات إضافية: ").strip()
        cmd = f"wfuzz -w {wordlist} {options} {url}"
        execute_and_log(session, cmd)
    
    elif choice == '10':  # Dirb
        url = input("URL: ").strip()
        wordlist = input("قائمة كلمات (افتراضي: common.txt): ").strip()
        if wordlist:
            cmd = f"dirb {url} {wordlist}"
        else:
            cmd = f"dirb {url}"
        execute_and_log(session, cmd)
    
    elif choice == '11':  # Sqlmap
        url = input("URL مع معامل (مثال: http://site.com/page.php?id=1): ").strip()
        options = input("خيارات إضافية: ").strip()
        cmd = f"sqlmap -u {url} {options}"
        execute_and_log(session, cmd)
    
    elif choice == '12':  # John the Ripper
        hash_file = input("ملف التجزئة: ").strip()
        wordlist = input("قائمة كلمات (اختياري): ").strip()
        if wordlist:
            cmd = f"john --wordlist={wordlist} {hash_file}"
        else:
            cmd = f"john {hash_file}"
        execute_and_log(session, cmd)
    
    elif choice == '13':  # أمر مخصص
        cmd = input("أدخل الأمر كاملاً: ").strip()
        if cmd:
            execute_and_log(session, cmd)
    
    elif choice == '14':  # حفظ الجلسة
        filename = input("اسم الملف (اترك فارغاً لاسم تلقائي): ").strip()
        session.save(filename if filename else None)
    
    elif choice == '15':  # عرض سجل الأوامر
        print(f"\n{Colors.BOLD}📜 سجل الأوامر ({len(session.commands)} أمر):{Colors.ENDC}")
        for i, cmd in enumerate(session.commands, 1):
            print(f"{i}. {cmd['time']}: {cmd['command'][:80]}...")
    
    elif choice == '0':
        return False
    else:
        print(f"{Colors.FAIL}اختيار غير صالح.{Colors.ENDC}")
    return True

