class ProScanner:
    def __init__(self, url, modules):
        if not url.startswith(('http://', 'https://')):
            url = 'https://' + url
        self.url=url; self.domain=urlparse(url).netloc
        self.modules=set(modules); self.vulns=[]; self.info=[]
        self.session=req.Session()
        self.session.headers.update({'User-Agent':'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'})
        self.base_response=None

    def vuln(self,vtype,severity,desc,rec,impact='',evidence=''):
        self.vulns.append({'type':vtype,'severity':severity,'description':desc,'recommendation':rec,'impact':impact,'evidence':evidence,'timestamp':datetime.now().strftime('%Y-%m-%d %H:%M:%S')})

    def info_add(self,title,value):
        self.info.append({'title':title,'value':str(value)})

    def get_base(self):
        if not self.base_response:
            try: self.base_response=self.session.get(self.url,timeout=10,verify=False)
            except: pass
        return self.base_response

    def check_ssl(self):
        if 'ssl' not in self.modules: return
        if self.url.startswith('http://'):
            self.vuln('Missing HTTPS','high','الموقع لا يستخدم HTTPS','استخدم SSL Certificate','MITM Attack','Protocol: http://'); return
        try:
            ctx=ssl.create_default_context()
            with socket.create_connection((self.domain,443),timeout=5) as s:
                with ctx.wrap_socket(s,server_hostname=self.domain) as ss:
                    cert=ss.getpeercert(); exp=datetime.strptime(cert['notAfter'],'%b %d %H:%M:%S %Y %Z')
                    days=(exp-datetime.now()).days; ver=ss.version()
                    self.info_add('SSL Version',ver); self.info_add('SSL Expires',f'{days} days')
                    if days<30: self.vuln('SSL Expiring','medium',f'SSL ينتهي خلال {days} يوم','جدد الشهادة','انقطاع الخدمة',f'Expires: {exp.strftime("%Y-%m-%d")}')
                    if ver in('TLSv1','TLSv1.1'): self.vuln('Weak TLS','medium',f'{ver} قديم وغير آمن','استخدم TLS 1.3','POODLE/BEAST',f'Version: {ver}')
        except ssl.SSLCertVerificationError as e: self.vuln('Invalid SSL','high','شهادة SSL غير صالحة','جدد من CA موثوق','MITM',str(e)[:80])
        except Exception as e: self.info_add('SSL Error',str(e)[:80])

    def check_headers(self):
        if 'headers' not in self.modules: return
        r=self.get_base()
        if not r: return
        h=r.headers
        self.info_add('HTTP Status',r.status_code)
        if 'Server' in h: self.info_add('Server',h['Server']); self.vuln('Server Disclosure','low',f"Server: {h['Server']}",'أخفِ Server header','Info leak',f"Server: {h['Server']}")
        if 'X-Powered-By' in h: self.vuln('Tech Disclosure','low',f"X-Powered-By: {h['X-Powered-By']}",'أزل هذا الـ header','Info leak',f"X-Powered-By: {h['X-Powered-By']}")
        for hdr,sev,desc,rec,impact in [
            ('X-Frame-Options','medium','عرضة لـ Clickjacking','أضف: X-Frame-Options: DENY','Clickjacking'),
            ('X-XSS-Protection','low','حماية XSS معطلة','أضف: X-XSS-Protection: 1; mode=block','XSS'),
            ('X-Content-Type-Options','low','عرضة لـ MIME Sniffing','أضف: X-Content-Type-Options: nosniff','MIME Sniffing'),
            ('Strict-Transport-Security','high','لا يوجد HSTS','أضف: Strict-Transport-Security: max-age=31536000','SSL Stripping'),
            ('Content-Security-Policy','high','لا يوجد CSP','أضف CSP مناسب','XSS المتقدم'),
            ('Referrer-Policy','low','لا يوجد Referrer-Policy','أضف: Referrer-Policy: strict-origin-when-cross-origin','Info Leak'),
            ('Permissions-Policy','low','لا يوجد Permissions-Policy','أضف Permissions-Policy','Unrestricted APIs'),
        ]:
            if hdr not in h: self.vuln(f'Missing: {hdr}',sev,desc,rec,impact,'Header absent')

    def check_sql(self):
        if 'sql' not in self.modules: return
        payloads=["'",'"',"' OR '1'='1","'; DROP TABLE--"]
        errors=['sql syntax','mysql_fetch','ora-01','microsoft ole db','unclosed quotation','sqlite_exception','postgresql','you have an error in your sql','warning: mysql']
        r=self.get_base()
        if not r: return
        try:
            soup=BeautifulSoup(r.text,'html.parser')
            for form in soup.find_all('form'):
                action=form.get('action',''); form_url=urljoin(self.url,action)
                inputs=form.find_all('input')
                for pl in payloads:
                    data={inp.get('name','test'):pl for inp in inputs if inp.get('name')}
                    if not data: continue
                    try:
                        resp=self.session.post(form_url,data=data,timeout=6,verify=False)
                        for err in errors:
                            if err in resp.text.lower(): self.vuln('SQL Injection','high',f'SQL Injection في: {form_url}','استخدم Prepared Statements','اختراق DB',f'Payload: {pl}'); return
                    except: pass
            if '?' in self.url:
                base,params=self.url.split('?',1)
                for pl in["'","' OR '1'='1"]:
                    try:
                        resp=self.session.get(f"{base}?{params}{pl}",timeout=5,verify=False)
                        for err in errors:
                            if err in resp.text.lower(): self.vuln('SQL Injection (GET)','high','SQL Injection في URL params','تحقق من URL params','اختراق DB',f'{params}{pl}'); return
                    except: pass
        except: pass

    def check_xss(self):
        if 'xss' not in self.modules: return
        payloads=['<script>alert(1)</script>','"><script>alert(1)</script>',"'><img src=x onerror=alert(1)>",'<svg onload=alert(1)>']
        r=self.get_base()
        if not r: return
        try:
            soup=BeautifulSoup(r.text,'html.parser')
            for form in soup.find_all('form'):
                action=form.get('action',''); form_url=urljoin(self.url,action)
                inputs=form.find_all('input')
                for pl in payloads:
                    data={inp.get('name','test'):pl for inp in inputs if inp.get('name')}
                    if not data: continue
                    try:
                        resp=self.session.post(form_url,data=data,timeout=5,verify=False)
