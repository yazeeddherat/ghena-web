                    except: pass
        except: pass

    def check_files(self):
        if 'files' not in self.modules: return
        for fpath,fdesc in[('/.env','Env secrets'),('/.git/config','Git config'),('/.git/HEAD','Git repo'),('/config.php','PHP config'),('/wp-config.php','WordPress config'),('/admin','Admin panel'),('/phpmyadmin','phpMyAdmin'),('/robots.txt','Robots'),('/.htaccess','Apache config'),('/backup.zip','Backup'),('/backup.sql','DB backup'),('/.DS_Store','Mac metadata'),('/config.yml','YAML config'),('/web.config','IIS config'),('/server-status','Apache status'),('/api/v1/users','API users'),('/composer.json','PHP deps'),('/package.json','Node deps'),('/.bash_history','Shell history'),('/debug','Debug endpoint')]:
            try:
                url=self.url.rstrip('/')+fpath
                resp=self.session.get(url,timeout=4,verify=False,allow_redirects=False)
                if resp.status_code==200 and len(resp.content)>0: self.vuln('Sensitive File','high',f'ملف مكشوف: {fpath} ({fdesc})','احذف أو احمِ الملف','تسريب credentials',f'URL: {url}')
            except: pass

    def check_cors(self):
        if 'cors' not in self.modules: return
        try:
            r=self.session.get(self.url,timeout=8,verify=False,headers={'Origin':'https://evil.com'})
            acao=r.headers.get('Access-Control-Allow-Origin',''); acac=r.headers.get('Access-Control-Allow-Credentials','')
            if acao=='*': self.vuln('CORS Wildcard','medium','CORS مضبوط على *','حدد origins المسموح بها','سرقة بيانات','ACAO: *')
            elif 'evil.com' in acao: self.vuln('CORS Misconfiguration','high' if acac.lower()=='true' else 'medium',f'يثق بـ origin خبيث','تحقق من Origin','CSRF + سرقة بيانات',f'ACAO: {acao}')
        except: pass

    def check_csrf(self):
        if 'csrf' not in self.modules: return
        r=self.get_base()
        if not r: return
        try:
            soup=BeautifulSoup(r.text,'html.parser')
            for form in soup.find_all('form',method=lambda m:m and m.lower()=='post'):
                inputs=form.find_all('input')
                if not any(kw in(i.get('name','')+i.get('id','')).lower() for i in inputs for kw in['csrf','token','nonce','_token']):
                    self.vuln('Missing CSRF Token','medium',f'Form POST بدون CSRF token','أضف CSRF token','تنفيذ إجراءات غير مصرح بها',f'Form: {urljoin(self.url,form.get("action",""))}'); break
        except: pass

    def check_cookies(self):
        if 'cookies' not in self.modules: return
        r=self.get_base()
        if not r: return
        sc=r.headers.get('Set-Cookie','').lower()
        for name in r.cookies:
            if name.lower() in['session','sessionid','phpsessid','jsessionid','auth','token']:
                issues=[f for f,k in[('HttpOnly','httponly'),('Secure','secure'),('SameSite','samesite')] if k not in sc]
                if issues: self.vuln('Insecure Cookie','medium',f'Cookie "{name}" يفتقر لـ: {", ".join(issues)}','أضف HttpOnly; Secure; SameSite=Strict','سرقة Session',f'Missing: {", ".join(issues)}')

    def check_redirect(self):
        if 'redirect' not in self.modules: return
        for param in['redirect','url','next','return','goto','dest','target']:
            try:
                resp=self.session.get(f"{self.url}?{param}=https://evil.com",timeout=5,verify=False,allow_redirects=False)
                if resp.status_code in(301,302,303,307,308) and 'evil.com' in resp.headers.get('Location',''):
                    self.vuln('Open Redirect','medium',f'Open Redirect عبر "{param}"','تحقق من URL','Phishing',f'?{param}=https://evil.com'); return
            except: pass

    def check_api(self):
        if 'api' not in self.modules: return
        found=[]
        for ep in['/api','/api/v1','/api/v2','/graphql','/swagger.json','/openapi.json','/api-docs','/api/users','/api/admin','/api/v1/users','/api/config']:
            try:
                url=self.url.rstrip('/')+ep
                resp=self.session.get(url,timeout=4,verify=False,allow_redirects=False)
                if resp.status_code in(200,401,403):
                    found.append(f'{ep}[{resp.status_code}]')
                    if resp.status_code==200 and ('json' in resp.headers.get('Content-Type','') or resp.text.strip().startswith(('{','['))):
                        self.vuln('Exposed API','medium',f'API مكشوف: {url}','أضف authentication','وصول غير مصرح',f'Status: 200')
            except: pass
        if found: self.info_add('API Endpoints',', '.join(found[:5]))

    def check_info(self):
        if 'info' not in self.modules: return
        r=self.get_base()
        if not r: return
        for pattern,vtype,sev in[(r'(?:password|passwd)\s*[=:]\s*["\']?[\w@#$%]+','Password in Source','high'),(r'api[_-]?key\s*[=:]\s*["\']?[\w\-]+','API Key in Source','high'),(r'(?:mysql|postgresql|mongodb):\/\/[\w:@\./]+','DB Connection String','high'),(r'(?:stack trace|traceback|exception in thread)','Stack Trace Exposed','medium')]:
            m=re.search(pattern,r.text,re.IGNORECASE)
            if m: self.vuln(vtype,sev,f'{vtype} في source code','أزل المعلومات الحساسة','تسريب معلومات',f'Found: {m.group(0)[:60]}')

    def check_dns(self):
        if 'dns' not in self.modules: return
        try: self.info_add('IP Address',socket.gethostbyname(self.domain))
        except Exception as e: self.info_add('DNS Error',str(e)); return
        try:
            import dns.resolver
            try:
                txts=dns.resolver.resolve(self.domain,'TXT')
                if not any('v=spf1' in str(r) for r in txts): self.vuln('Missing SPF','medium','لا يوجد SPF Record','أضف SPF في DNS','Email Spoofing',f'Domain: {self.domain}')
            except: pass
            try:
                mx=dns.resolver.resolve(self.domain,'MX')
                self.info_add('MX Records',', '.join(str(r.exchange) for r in mx)[:80])
            except: pass
        except ImportError: pass

    def run(self):
        start=datetime.now()
        self.info_add('Target',self.url); self.info_add('Domain',self.domain); self.info_add('Scan Date',start.strftime('%Y-%m-%d %H:%M:%S'))
        self.check_ssl(); self.check_headers(); self.check_sql(); self.check_xss()
        self.check_files(); self.check_cors(); self.check_csrf(); self.check_cookies()
        self.check_redirect(); self.check_api(); self.check_info(); self.check_dns()
        duration=(datetime.now()-start).seconds
        summary={'total':len(self.vulns),'high':sum(1 for v in self.vulns if v['severity']=='high'),'medium':sum(1 for v in self.vulns if v['severity']=='medium'),'low':sum(1 for v in self.vulns if v['severity']=='low'),'info':sum(1 for v in self.vulns if v['severity']=='info')}
        return{'target':self.url,'domain':self.domain,'scan_date':start.strftime('%Y-%m-%d %H:%M:%S'),'duration':duration,'modules_run':','.join(self.modules),'vulnerabilities':self.vulns,'info':self.info,'summary':summary}

