# =====================================================
# Rate Limiter
# =====================================================
scan_counts_hour   = defaultdict(list)
scan_counts_minute = defaultdict(list)
blocked_ips        = {}

def get_ip():
    return request.headers.get('X-Forwarded-For', request.remote_addr).split(',')[0].strip()

def check_rate_limit(ip):
    now = time.time()

    # تنظيف القوائم القديمة
    scan_counts_hour[ip]   = [t for t in scan_counts_hour[ip]   if t > now - 3600]
    scan_counts_minute[ip] = [t for t in scan_counts_minute[ip] if t > now - 60]

    # فحص الحد في الساعة
    if len(scan_counts_hour[ip]) >= CONFIG['MAX_SCANS_PER_HOUR']:
        return False, f'تجاوزت الحد المسموح ({CONFIG["MAX_SCANS_PER_HOUR"]} فحص/ساعة) — انتظر قليلاً'

    # فحص الحد في الدقيقة
    if len(scan_counts_minute[ip]) >= CONFIG['MAX_SCANS_PER_MINUTE']:
        return False, f'سرعة فحص عالية — انتظر 30 ثانية'

    return True, ''

def record_scan(ip):
    now = time.time()
    scan_counts_hour[ip].append(now)
    scan_counts_minute[ip].append(now)

