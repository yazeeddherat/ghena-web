# ================= إدارة الجلسات =================
class Session:
    def __init__(self, target: str, platform: str):
        self.target = target
        self.platform = platform
        self.steps = []
        self.findings = {}
        self.shell_obtained = False
        self.ai_enabled = self._init_ai()
    
    def _init_ai(self):
        try:
            genai.configure(api_key=API_KEY)
            # استخدام نموذج 1.0 Pro للتوافقية الأوسع
            self.ai_model = genai.GenerativeModel(
                model_name="gemini-1.0-pro",
                generation_config=GENERATION_CONFIG,
                safety_settings=SAFETY_SETTINGS
            )
            self.ai_chat = self.ai_model.start_chat(history=[])
            return True
        except Exception as e:
            print(f"{Colors.FAIL}⚠️ فشل تشغيل الذكاء الاصطناعي: {e}{Colors.ENDC}")
            return False
    
    def add_step(self, step_name: str, data: any):
        self.steps.append({
            "time": datetime.datetime.now().isoformat(),
            "step": step_name,
            "data": data
        })
    
    def save(self, filename: str = None):
        if not filename:
            filename = f"session_{self.target.replace('.', '_')}_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        with open(filename, 'w') as f:
            json.dump({
                "target": self.target,
                "platform": self.platform,
                "steps": self.steps,
                "findings": self.findings,
                "shell_obtained": self.shell_obtained
            }, f, indent=2)
        print(f"{Colors.GREEN}💾 تم حفظ الجلسة في {filename}{Colors.ENDC}")
        return filename
    
    @staticmethod
    def load(filename: str):
        with open(filename, 'r') as f:
            data = json.load(f)
        session = Session(data['target'], data['platform'])
        session.steps = data['steps']
        session.findings = data.get('findings', {})
        session.shell_obtained = data.get('shell_obtained', False)
        return session

# ================= أدوات مساعدة =================
def run_command(cmd: str) -> str:
    """تنفيذ أمر وعودة الناتج (مع معالجة الأخطاء)"""
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=60)
        return result.stdout + result.stderr
    except Exception as e:
        return f"خطأ في تنفيذ الأمر: {e}"

def extract_services_from_nmap(nmap_output: str) -> List[str]:
    """استخراج أسماء الخدمات من مخرجات nmap"""
    services = set()
    for line in nmap_output.splitlines():
        match = re.search(r'\d+/(tcp|udp)\s+open\s+(\S+)', line)
        if match:
            services.add(match.group(2).lower())
    return list(services)

def search_exploit(service_version: str) -> str:
    """البحث عن استغلال باستخدام searchsploit"""
    try:
        result = subprocess.run(f"searchsploit {service_version}", shell=True, capture_output=True, text=True)
        return result.stdout
    except:
        return "لم يتم العثور على searchsploit أو حدث خطأ."

def ask_yes_no(question: str) -> bool:
    answer = input(f"{Colors.CYAN}❓ {question} (y/n): {Colors.ENDC}").strip().lower()
    return answer.startswith('y')

def choose_from_list(options: List[str], prompt: str) -> str:
    print(f"{Colors.BLUE}{prompt}{Colors.ENDC}")
    for i, opt in enumerate(options):
        print(f"  {i+1}. {opt}")
    while True:
        choice = input(f"{Colors.CYAN}اختر رقم (أو 0 للتراجع): {Colors.ENDC}").strip()
        if choice.isdigit():
            idx = int(choice) - 1
            if 0 <= idx < len(options):
                return options[idx]
        print(f"{Colors.FAIL}إدخال غير صالح.{Colors.ENDC}")

