        return jsonify({'error':msg}),429

    data=request.get_json()
    if not data:
        return jsonify({'error':'بيانات غير صالحة'}),400

    url=data.get('url','').strip()
    modules=data.get('modules',['ssl','headers','sql','xss','files','cors','csrf','cookies','redirect','api','info','dns'])

    # Validate
    valid,result=validate_url(url)
    if not valid:
        log_event('BLOCKED',f'Invalid URL: {url} — {result}')
        return jsonify({'error':result}),400

    url=result
    record_scan(ip)
    log_event('SCAN',f'Scanning: {url}')

    try:
        results=ProScanner(url,modules).run()
        log_event('DONE',f'{url} | Total:{results["summary"]["total"]} High:{results["summary"]["high"]}')
        return jsonify(results)
    except Exception as e:
        log_event('ERROR',f'{url}: {str(e)}')
        return jsonify({'error':str(e)}),500

